PORT=4000
NODE_ENV=development
APP_ROOT_DOMAINS=mydomain.com
LOCALHOST_ROOT_DOMAINS=localhost,lvh.me,127.0.0.1.nip.io
ALLOWED_LOCAL_APP_PORTS=3000,3001
ALLOWED_PRODUCTION_APP_PORTS=
ALLOWED_ORIGINS=
MONGODB_URI=mongodb://127.0.0.1:27017/medspa_rewards
KEYCLOAK_ISSUER=https://auth.mydomain.com/realms/medspa
KEYCLOAK_AUDIENCE=medspa-api
KEYCLOAK_JWKS_URI=https://auth.mydomain.com/realms/medspa/protocol/openid-connect/certs
KEYCLOAK_CLOCK_TOLERANCE=5
KEYCLOAK_LOCAL_REDIRECT_URIS=http://localhost:3000/*,http://*.localhost:3000/*,http://localhost:3001/*,http://*.localhost:3001/*
KEYCLOAK_ADMIN_CLIENT_ID=admin-cli
KEYCLOAK_ADMIN_CLIENT_SECRET=
QR_TOKEN_SECRET=change-me
QR_TOKEN_TTL_MINUTES=15
